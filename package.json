{
  "name": "todolist-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "node --import tsx --test tests/integration/api.test.ts",
    "check": "tsc -p tsconfig.server.json --noEmit && node --import tsx --test tests/integration/api.test.ts"
  },
  "dependencies": {
    "sql.js": "^1.11.0",
    "cors": "^2.8.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
