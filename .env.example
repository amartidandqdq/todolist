# === OBLIGATOIRE ===

# Cle Tailscale
# Genere-la sur : https://login.tailscale.com/admin/settings/keys
# Coche "Reusable" lors de la creation
TAILSCALE_AUTHKEY=tskey-auth-xxxxx

# === OPTIONNEL ===

# Nom de l'app dans Tailscale (URL: https://todolist.<ton-tailnet>.ts.net)
TS_HOSTNAME=todolist

# Port interne (pas besoin de changer)
PORT=3000

# Chemin des donnees (utile pour TrueNAS: pointer vers un dataset ZFS)
# Exemples:
#   TrueNAS Scale: /mnt/pool/apps/todolist/data
#   TrueNAS Core:  /mnt/tank/apps/todolist/data
#   Par defaut:    ./data
DATA_PATH=./data
