# === OBLIGATOIRE ===

# Cle Tailscale
# Genere-la sur : https://login.tailscale.com/admin/settings/keys
# Coche "Reusable" lors de la creation
TAILSCALE_AUTHKEY=tskey-auth-xxxxx

# === OPTIONNEL (serveur) ===

# Nom de l'app dans Tailscale (URL: https://todolist.<ton-tailnet>.ts.net)
TS_HOSTNAME=todolist

# Port interne
PORT=3000

# Chemin des donnees SQLite (utile pour TrueNAS: pointer vers un dataset ZFS)
DATA_PATH=./data

# Intervalle de flush DB vers disque (ms)
DB_SAVE_INTERVAL=5000

# Limite de taille du body JSON Express
JSON_LIMIT=1mb

# Cache-Control max-age pour les fichiers statiques
STATIC_MAX_AGE=1d

# Niveau de log: debug | info | warn | error
LOG_LEVEL=info

# Taille max du fichier de log avant rotation (octets)
LOG_MAX_SIZE=5242880

# Couleur par defaut des nouvelles listes
DEFAULT_LIST_COLOR=#4285f4

# ID de la liste par defaut pour les taches sans list_id
DEFAULT_LIST_ID=1

# === CLIENT-SIDE (modifier dans le code source) ===
# Auto-refresh interval: client/src/hooks/useAppState.ts (30000 ms)
# Undo toast timeout: client/src/components/UndoToast.tsx (5000 ms)
